# Environment variables declared in this file are automatically made available to Prisma.
# See the documentation for more detail: https://pris.ly/d/prisma-schema#accessing-environment-variables-from-the-schema

# Prisma supports the native connection string format for PostgreSQL, MySQL, SQLite, SQL Server, MongoDB and CockroachDB.
# See the documentation for all the connection string options: https://pris.ly/d/connection-strings

DATABASE_URL="file:./dev.db"

# Authentication
NEXTAUTH_SECRET="dpp-demo-secret-key-for-eidas-simulation-2026"
NEXTAUTH_URL="http://localhost:3000"

# GDPR
GDPR_DATA_RETENTION_DAYS=730
GDPR_LOG_ANONYMIZATION_DAYS=180

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Demo Mode
DEMO_MODE=true
DEMO_ROLE_SWITCHING=true

# EU Compliance
EU_DATA_RESIDENCY="stockholm"
ESPR_VERSION="1.0"

# GS1 Digital Link
GS1_BASE_URI="https://dpp.brand.com/01/"