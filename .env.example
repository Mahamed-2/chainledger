# Database connection (SQLite for local demo, change to Postgres for Vercel/Prod)
DATABASE_URL="file:./dev.db"

# NextAuth Configuration
NEXTAUTH_SECRET="A_SECURE_RANDOM_STRING_HERE"
NEXTAUTH_URL="http://localhost:3000"

# GDPR Compliance Settings
GDPR_DATA_RETENTION_DAYS="730"
GDPR_LOG_ANONYMIZATION_DAYS="180"

# Rate Limiting
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX_REQUESTS="100"

# Application Modes
NEXT_PUBLIC_DEMO_MODE="true"
DEMO_ROLE_SWITCHING="true"

# EU Product Settings
EU_DATA_RESIDENCY="stockholm"
ESPR_VERSION="1.0"
GS1_BASE_URI="https://dpp.brand.com/01/"
